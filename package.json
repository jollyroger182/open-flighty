{
	"name": "open-flighty",
	"version": "0.3.0",
	"type": "module",
	"scripts": {
		"check": "tsc --noEmit",
		"gen": "rm -rf src/gen && buf generate",
		"build": "bun ./scripts/build.ts",
		"prepublishOnly": "bun run build"
	},
	"files": [
		"index.ts",
		"src",
		"dist"
	],
	"main": "./dist/cjs/index.js",
	"module": "./dist/esm/index.js",
	"types": "./index.ts",
	"exports": {
		".": {
			"types": "./index.ts",
			"bun": "./index.ts",
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.js",
			"default": "./dist/esm/index.js"
		}
	},
	"devDependencies": {
		"@bufbuild/buf": "^1.69.0",
		"@bufbuild/protoc-gen-es": "^2.12.0",
		"@types/bun": "latest",
		"prettier": "^3.8.3",
		"prettier-plugin-jsdoc": "^1.8.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@bufbuild/protobuf": "^2.12.0"
	}
}
